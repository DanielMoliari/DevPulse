# ─── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development

# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:26772/devpulse

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:41356

# ─── GitHub OAuth ──────────────────────────────────────────────────────────────
# Create at: https://github.com/settings/developers → OAuth Apps
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_CALLBACK_URL=http://localhost:17642/api/v1/auth/github/callback

# ─── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d

# ─── API ───────────────────────────────────────────────────────────────────────
PORT=17642
ALLOWED_ORIGINS=http://localhost:38929

# ─── Next.js ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:17642
NEXTAUTH_URL=http://localhost:38929
NEXTAUTH_SECRET=change-this-to-a-long-random-string-in-production
